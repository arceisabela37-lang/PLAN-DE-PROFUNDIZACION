ALGORITMO PUNTAJE_JUEGO
   DEFINIR MONEDAS, NIVELES, PUNTAJETOTAL COMO ENTERO

   ESCRIBIR "INGRESE LA CANTIDAD DE MONEDAS RECOLECTADAS:"
   LEER MONEDAS

   ESCRIBIR "INGRESE LA CANTIDAD DE NIVELES SUPERADOS:"
   LEER NIVELES
   // CADA MONEDA VALE 100 Y CADA NIVEL 500//
   PUNTAJETOTAL <- (MONEDAS * 100) + (NIVELES * 500)
   ESCRIBIR "EL PUNTAJE TOTAL ES: ", PUNTAJETOTAL
FINALGORITMO
